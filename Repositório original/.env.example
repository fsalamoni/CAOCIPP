# Firebase Environment Variables
# IMPORTANT: Add .env to .gitignore!

# Firebase Configuration (get from Firebase Console > Project Settings > General)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
# Optional: App Configuration (Specific to Consultas CAO)
VITE_CONSULTAS_CAO_APP_ID=your_app_id
VITE_CONSULTAS_CAO_FUNCTIONS_VERSION=v2
VITE_CONSULTAS_CAO_APP_BASE_URL=https://your-app.web.app
VITE_CONSULTAS_CAO_LEGACY_SDK_IMPORTS=false
