rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========== HELPER FUNCTIONS ==========
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isMemberOf(orgId) {
      return exists(/databases/$(database)/documents/userOrganizations/$(request.auth.uid + '_' + orgId));
    }
    
    function getMembership(orgId) {
      return get(/databases/$(database)/documents/userOrganizations/$(request.auth.uid + '_' + orgId)).data;
    }
    
    function hasRole(orgId, allowedRoles) {
      let membership = getMembership(orgId);
      return membership.role in allowedRoles;
    }
    
    // Super-admin de plataforma (custom claim emitido por Cloud Function)
    function isPlatformAdmin() {
      return isAuthenticated() && request.auth.token.platformAdmin == true;
    }
    
    // ========== USERS ==========
    
    match /users/{userId} {
      // Todos usuários autenticados podem ler perfis (para exibir nomes, fotos)
      allow read: if isAuthenticated();
      
      // Apenas o próprio usuário pode escrever seu perfil
      allow write: if isAuthenticated() && isOwner(userId);
    }
    
    // ========== ORGANIZATIONS ==========
    
    match /organizations/{orgId} {
      // Apenas membros da organização podem ler
      allow read: if isAuthenticated() && isMemberOf(orgId);
      
      // Qualquer usuário autenticado pode criar uma organização
      allow create: if isAuthenticated();
      
      // Apenas creator ou admin podem atualizar/deletar
      allow update, delete: if isAuthenticated() && 
                              isMemberOf(orgId) && 
                              hasRole(orgId, ['creator', 'admin']);
    }
    
    // ========== USER ORGANIZATIONS (Memberships) ==========
    
    match /userOrganizations/{membershipId} {
      // Qualquer usuário autenticado pode ler memberships (para ver membros)
      allow read: if isAuthenticated();
      
      // Usuário pode criar seu próprio membership (join via invite code)
      allow create: if isAuthenticated();
      
      // Pode atualizar/deletar se for:
      // 1. Admin/creator da organização, OU
      // 2. O próprio usuário (sair da organização)
      allow update, delete: if isAuthenticated() && (
        (isMemberOf(resource.data.organization_id) && 
         hasRole(resource.data.organization_id, ['creator', 'admin'])) ||
        isOwner(resource.data.user_id)
      );
    }
    
    // ========== PROCESSES ==========
    
    match /processes/{processId} {
      // Membros da organização podem ler processos
      allow read: if isAuthenticated() && isMemberOf(resource.data.organization_id);
      
      // Membros podem criar processos
      allow create: if isAuthenticated() && 
                      isMemberOf(request.resource.data.organization_id);
      
      // Pode atualizar se for:
      // 1. Admin/creator da organização, OU
      // 2. Responsável pelo processo
      allow update: if isAuthenticated() && 
                      isMemberOf(resource.data.organization_id) && (
                        hasRole(resource.data.organization_id, ['creator', 'admin']) ||
                        isOwner(resource.data.responsible_user_id)
                      );
      
      // Apenas admin/creator podem deletar
      allow delete: if isAuthenticated() && 
                      isMemberOf(resource.data.organization_id) &&
                      hasRole(resource.data.organization_id, ['creator', 'admin']);

      // Subcoleção de histórico (Fase 3). Leitura para membros do órgão do
      // processo pai; escrita exclusiva de Cloud Functions (Admin SDK).
      match /history/{entryId} {
        allow read: if isAuthenticated() &&
          isMemberOf(get(/databases/$(database)/documents/processes/$(processId)).data.organization_id);
        allow write: if false;
      }
    }
    
    // ========== EXPEDIENTES ADMINISTRATIVOS ==========
    
    match /expedientes/{expedienteId} {
      // Membros da organização podem ler expedientes
      allow read: if isAuthenticated() && isMemberOf(resource.data.organization_id);
      
      // Membros podem criar expedientes
      allow create: if isAuthenticated() && 
                      isMemberOf(request.resource.data.organization_id);
      
      // Pode atualizar se for:
      // 1. Admin/creator da organização, OU
      // 2. Responsável pelo expediente
      allow update: if isAuthenticated() && 
                      isMemberOf(resource.data.organization_id) && (
                        hasRole(resource.data.organization_id, ['creator', 'admin']) ||
                        isOwner(resource.data.responsible_user_id)
                      );
      
      // Apenas admin/creator podem deletar
      allow delete: if isAuthenticated() && 
                      isMemberOf(resource.data.organization_id) &&
                      hasRole(resource.data.organization_id, ['creator', 'admin']);

      // Subcoleção de histórico (Fase 3). Leitura para membros do órgão do
      // expediente pai; escrita exclusiva de Cloud Functions (Admin SDK).
      match /history/{entryId} {
        allow read: if isAuthenticated() &&
          isMemberOf(get(/databases/$(database)/documents/expedientes/$(expedienteId)).data.organization_id);
        allow write: if false;
      }
    }

    // ========== PÁGINAS/PROCESSOS PERSONALIZADOS (flag: custom_entities) ==========
    // Definições dos tipos de entidade. Leitura para membros do órgão; toda
    // escrita passa por Cloud Functions (validação/sanitização no servidor).
    match /entityTypes/{typeId} {
      allow read: if isAuthenticated() && isMemberOf(resource.data.organization_id);
      allow write: if false;
    }

    // Registros das páginas personalizadas. Leitura para membros do órgão;
    // criação/edição/exclusão exclusivamente via Cloud Functions.
    match /customRecords/{recordId} {
      allow read: if isAuthenticated() && isMemberOf(resource.data.organization_id);
      allow write: if false;

      // Histórico espelhado (igual a processes/expedientes).
      match /history/{entryId} {
        allow read: if isAuthenticated() &&
          isMemberOf(get(/databases/$(database)/documents/customRecords/$(recordId)).data.organization_id);
        allow write: if false;
      }
    }
    
    // ========== AUDIT LOGS ==========
    
    match /auditLogs/{logId} {
      // Membros podem ler logs da organização
      allow read: if isAuthenticated() && isMemberOf(resource.data.organization_id);
      
      // NINGUÉM pode escrever diretamente - apenas Cloud Functions
      allow write: if false;
    }
    
    // ========== NOTIFICATIONS ==========
    
    match /notifications/{notifId} {
      // Apenas o destinatário pode ler suas notificações
      allow read: if isAuthenticated() && isOwner(resource.data.user_id);
      
      // Pode atualizar apenas para marcar como lida
      allow update: if isAuthenticated() && 
                      isOwner(resource.data.user_id) &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['read', 'read_at']);
      
      // Não pode criar/deletar - apenas Cloud Functions
      allow create, delete: if false;
    }

    // ========== PLATAFORMA: CONFIG / FEATURE FLAGS ==========

    match /platformConfig/{docId} {
      // Qualquer usuário autenticado pode LER as flags (controlam o comportamento
      // do app para todos). São apenas valores booleanos, não sensíveis.
      allow read: if isAuthenticated();

      // Escrita exclusiva de Cloud Functions (setFeatureFlag valida super-admin).
      allow write: if false;
    }

    // ========== PLATAFORMA: ALLOWLIST DE SUPER-ADMINS ==========

    match /platformAdmins/{uid} {
      // O próprio usuário pode ler seu registro (para o app saber se é admin),
      // e super-admins podem ler todos.
      allow read: if isAuthenticated() && (isOwner(uid) || isPlatformAdmin());

      // Escrita exclusiva de Cloud Functions (grant/revoke validam super-admin).
      allow write: if false;
    }

    // ========== PLATAFORMA: ESTATÍSTICAS AGREGADAS ==========

    match /platformStats/{docId} {
      // Apenas super-admin lê estatísticas globais.
      allow read: if isPlatformAdmin();

      // Escrita exclusiva de Cloud Functions (cron/agregadores).
      allow write: if false;
    }
  }
}
